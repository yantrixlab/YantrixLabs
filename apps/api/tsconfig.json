{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],

    "module": "commonjs",
    "moduleResolution": "node",

    "outDir": "./dist",

    "strict": false,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "sourceMap": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",

    "paths": {
      "@yantrix/shared-types": ["../../packages/shared-types/src"],
      "@yantrix/auth": ["../../packages/auth/src"],
      "@yantrix/billing": ["../../packages/billing/src"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/auth/src/**/*",
    "../../packages/billing/src/**/*",
    "../../packages/shared-types/src/**/*"
  ],

  "exclude": ["node_modules", "dist"]
}
