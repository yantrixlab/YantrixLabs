{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],

    "module": "commonjs",
    "moduleResolution": "node",

    "outDir": "./dist",

    "strict": false,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "sourceMap": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",

    "paths": {
      "@yantrix/shared-types": ["../../packages/shared-types/dist"],
      "@yantrix/auth": ["../../packages/auth/dist"],
      "@yantrix/billing": ["../../packages/billing/dist"]
    }
  },
  "include": ["src/**/*"],

  "exclude": ["node_modules", "dist"]
}
