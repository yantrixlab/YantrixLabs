# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/yantrix_db?schema=public"

# ─── Auth ────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="your-jwt-secret-min-32-chars-change-in-production"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your-refresh-token-secret-change-in-production"

# ─── API Server ──────────────────────────────────────────────────────────────
API_PORT=4000
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ─── Razorpay Payments ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# ─── Cloudinary (File Storage) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_URL="cloudinary://your-api-key:your-api-secret@your-cloud-name"

# ─── AWS S3 (Alternative Storage) ────────────────────────────────────────────
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="yantrix-uploads"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@yantrix.in"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="Yantrix <noreply@yantrix.in>"

# ─── SMS / OTP ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_PHONE_NUMBER="+1234567890"
# Or use MSG91
MSG91_AUTH_KEY="your-msg91-key"
MSG91_SENDER_ID="YANTRX"
MSG91_TEMPLATE_ID="your-otp-template-id"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── App Config ──────────────────────────────────────────────────────────────
NODE_ENV="development"
APP_NAME="Yantrix"
APP_URL="http://localhost:3000"
SUPPORT_EMAIL="support@yantrix.in"
ADMIN_EMAIL="admin@yantrix.in"

# ─── Next.js Public Vars (prefix NEXT_PUBLIC_) ───────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
NEXT_PUBLIC_APP_NAME="Yantrix"
